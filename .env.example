DATABASE_URL=postgresql://hubflo:hubflo@localhost:5432/hubflo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hosted pilot persistence. Leave blank locally to use .hubflo-runtime JSON files.
NEXA_STORE_PATH=

# Optional: real OpenAI-powered NeXa Takeoff extraction.
# Add the key to your local .env.local, not to git.
OPENAI_API_KEY=
NEXA_TAKEOFF_OPENAI_MODEL=gpt-5.5

# Optional: live quote handoff bridge into Simpro.
# Without this, quote handoffs are saved in NeXa's queue but are not sent to Simpro.
SIMPRO_QUOTE_PUSH_URL=
SIMPRO_QUOTE_PUSH_TOKEN=

# Optional: direct Simpro API mode when no bridge URL is used.
SIMPRO_API_BASE_URL=
SIMPRO_ACCESS_TOKEN=
SIMPRO_COMPANY_ID=
SIMPRO_DEFAULT_CUSTOMER_ID=
SIMPRO_DEFAULT_SITE_ID=

# WhatsApp Business / Cloud API pilot values
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
