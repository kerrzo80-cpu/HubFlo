DATABASE_URL=postgresql://hubflo:hubflo@localhost:5432/hubflo
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Hosted pilot persistence. Leave blank locally to use .hubflo-runtime JSON files.
NEXA_STORE_PATH=

# Optional: real OpenAI-powered NeXa Takeoff extraction.
# Add the key to your local .env.local, not to git.
OPENAI_API_KEY=
NEXA_TAKEOFF_OPENAI_MODEL=gpt-5.5

# WhatsApp Business / Cloud API pilot values
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=
